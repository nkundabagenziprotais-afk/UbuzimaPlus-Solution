{
  "name": "ubuzima-admin-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "native:sync": "npm run build && cap sync",
    "native:add:android": "cap add android",
    "native:add:ios": "cap add ios",
    "native:open:android": "npm run native:sync && cap open android",
    "native:open:ios": "npm run native:sync && cap open ios",
    "native:doctor": "cap doctor"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "6.4.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7"
  }
}
