Options -MultiViews
<IfModule mod_rewrite.c>
RewriteEngine On

# Send backend API requests to Laravel, not to the React SPA.
RewriteRule ^api(?:/.*)?$ /index.php [QSA,L]

# React public website SPA fallback.
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
</IfModule>
